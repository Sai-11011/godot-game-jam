bbcode_enabled = true
text = "[center][color=#c285ff]✦ THE TITAN AWAKENS ✦[/color][/center]

[center][color=#a3a3a3]\"For ages, the Titan lay dormant beneath the ruins.
Now, the purple eclipse spreads... it senses you.
You have to prepare for what comes next.

Gather shards to grow stronger.
But as you rise, so does the Titan.
When it awakens, there will be no escape.\"[/color][/center]

[center][color=#ff0000]♦[/color][color=#00ff00] ♦ [/color][color=#0000ff]♦[/color][/center]

[center][color=#ffffff][b]YOUR OBJECTIVE[/b][/color]
[color=#dddddd]Slay minions and harvest shards to upgrade stats.
Survive the Fight, then [color=#ff5555]destroy the Titan's
three orbiting cubes[/color] to expose its core![/color][/center]
"
fit_content = true
scroll_active = false
horizontal_alignment = 1
vertical_alignment = 1

